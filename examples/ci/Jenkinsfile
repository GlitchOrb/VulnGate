pipeline {
  agent any

  stages {
    stage('Build VulnGate') {
      steps {
        sh 'go build -o ./bin/vulngate ./cmd/vulngate'
      }
    }

    stage('Init DB') {
      steps {
        sh '''
          ./bin/vulngate db init --db ./vulngate.db
          ./bin/vulngate db import --db ./vulngate.db --source ./examples/vulndb/osv
        '''
      }
    }

    stage('Scan') {
      steps {
        sh '''
          set +e
          ./bin/vulngate scan --db ./vulngate.db . > results.sarif
          SCAN_EXIT=$?
          set -e
          echo "$SCAN_EXIT" > .vulngate_scan_exit
          if [ "$SCAN_EXIT" -eq 2 ]; then
            exit 2
          fi
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'results.sarif', fingerprint: true
      script {
        if (fileExists('.vulngate_scan_exit')) {
          def code = readFile('.vulngate_scan_exit').trim()
          if (code == '1') {
            error('VulnGate policy gate failed')
          }
        }
      }
    }
  }
}
